# Project Oracle environment — copy to <repo>/.env and fill in.
# Read by the systemd web service (EnvironmentFile) and the cron jobs
# (sourced by run-job.sh). Keep values simple: NO quotes, NO spaces.

TZ=Asia/Kolkata

# Web app admin login. ORACLE_ADMIN_PASSWORD is the source of truth: on startup
# the admin user is created if missing and its password is synced to this value,
# so changing it here + restarting rotates the login. Use a long value with no
# quotes/spaces. Keep it in sync with extensions/oracle-login/config.js.
ORACLE_ADMIN_USER=senthil
ORACLE_ADMIN_PASSWORD=set-a-long-random-password

# Gmail App Password (not your normal password) for notification emails
GMAIL_USER=you@gmail.com
GMAIL_PASS=your16charapppass

# Zerodha
ZERODHA_USER_ID=PC8006
# Credentials for the automated headless login (bees.bot relogin) that refreshes
# the enctoken daily at 3:29pm IST when the stored one has expired. ZERODHA_TOTP_SECRET
# is the base32 key shown when you enable an external TOTP/2FA app on Kite.
ZERODHA_PASSWORD=your-kite-password
ZERODHA_TOTP_SECRET=YOURBASE32TOTPSECRET

# --- enctoken ingest API (used by the Chrome extension) ---
# Basic-auth credentials the extension must send. Pick your own; they MUST
# match BASIC_USER / BASIC_PASS in the extension's popup.js.
ENCTOKEN_API_USER=oracle
ENCTOKEN_API_PASS=change-me-to-a-long-random-string
# Optional overrides (defaults shown):
# ENCTOKEN_API_PORT=8502
# ENCTOKEN_API_HOST=0.0.0.0
# ENCTOKEN_API_CORS_ORIGIN=https://kite.zerodha.com

# --- Everything below is OPTIONAL: these are the built-in defaults, and the
# --- relative paths resolve against the repo (the service/cron run there). ---
# DRIVE_ROOT_FOLDER=QuantData
# DRIVE_CREDENTIALS_PATH=credentials.json
# DRIVE_TOKEN_PATH=token.json
# DOWNLOADER_DATA_ROOT=data
# DOWNLOADER_KEEP_MONTHS=2
# DOWNLOADER_MAX_WORKERS=4
# DOWNLOADER_RAM_FLOOR_MB=200
# DOWNLOADER_RAM_PER_WORKER_MB=50
# DOWNLOADER_MIN_RAM_MB=20
# DOWNLOADER_MIN_FREE_DISK_MB=2000
