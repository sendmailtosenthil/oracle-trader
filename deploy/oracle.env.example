# Project Oracle environment — copy to <repo>/.env and fill in.
# Read by the systemd web service (EnvironmentFile) and the cron jobs
# (sourced by run-job.sh). Keep values simple: NO quotes, NO spaces.

TZ=Asia/Kolkata

# Gmail App Password (not your normal password) for notification emails
GMAIL_USER=you@gmail.com
GMAIL_PASS=your16charapppass

# Zerodha
ZERODHA_USER_ID=PC8006

# --- Everything below is OPTIONAL: these are the built-in defaults, and the
# --- relative paths resolve against the repo (the service/cron run there). ---
# DRIVE_ROOT_FOLDER=QuantData
# DRIVE_CREDENTIALS_PATH=credentials.json
# DRIVE_TOKEN_PATH=token.json
# DOWNLOADER_DATA_ROOT=data
# DOWNLOADER_KEEP_MONTHS=2
# DOWNLOADER_MAX_WORKERS=4
# DOWNLOADER_RAM_FLOOR_MB=200
# DOWNLOADER_RAM_PER_WORKER_MB=50
# DOWNLOADER_MIN_RAM_MB=20
# DOWNLOADER_MIN_FREE_DISK_MB=2000
