{
  "manifest_version": 3,
  "name": "Oracle Web Login",
  "version": "1.0.0",
  "description": "One click: opens the Project Oracle web app and logs in automatically.",
  "permissions": ["tabs"],
  "host_permissions": ["http://129.159.236.137:8501/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open & log in to Oracle",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://129.159.236.137:8501/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
