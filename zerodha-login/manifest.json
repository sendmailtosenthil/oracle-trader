{
  "manifest_version": 3,
  "name": "Zerodha Kite Auto-Login",
  "version": "1.0.0",
  "description": "One click: opens Kite and logs in with your user id, password and time-based OTP.",
  "permissions": ["tabs"],
  "host_permissions": ["https://kite.zerodha.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Log in to Zerodha Kite",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://kite.zerodha.com/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
